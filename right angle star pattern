import java.util.Scanner;
class Solution{
      public static void main(String[]args){
      Scanner as=new Scanner(System.in);
      int n=as.nextInt();
         for(int i=n;i>=1;i--){
             for(int j=1;j<=i;j++){
                 System.out.print("*");
             }
             System.out.println();
         }
    }
}
