import java.util.Scanner;
public class Solution {
    public static void main(String[]args) 
        { 
        Scanner sc=new Scanner(System.in);
       int even=0, odd=0;
        for(int i=1; i<=10; i++){
        
            if(i % 2 == 0)
              even += i;
        
        else
        
            odd += i;
        }
        System.out.println("Even="+ even);
        System.out.println("odd="+odd);
       }
}
