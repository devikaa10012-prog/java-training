import java.util.Scanner;
class Solution{
    public static void main(String[]args){
    Scanner as=new Scanner(System.in);
    int n=as.nextInt();
    int[]arr=new int[n];
    for(int i=0;i<n;i++){
        arr[i]=as.nextInt();
    }
    for(int i=0;i<n;i++){
        System.out.print(arr[i]+" ");
      }
    }
}
